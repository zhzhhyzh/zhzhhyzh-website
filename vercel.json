{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.txt", "use": "@vercel/static" },
    { "src": "*.xml", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" }
  ],
  "redirects": [
    {
      "source": "/dev-tools",
      "destination": "https://zhzhhyzh-dev-tools.vercel.app/",
      "permanent": false
    },
    {
      "source": "/dev-tools/(.*)",
      "destination": "https://zhzhhyzh-dev-tools.vercel.app/$1",
      "permanent": false
    },
    {
      "source": "/pdf-tools",
      "destination": "https://zhzhhyzh-pdf-tools.vercel.app/",
      "permanent": false
    },
    {
      "source": "/pdf-tools/(.*)",
      "destination": "https://zhzhhyzh-pdf-tools.vercel.app/$1",
      "permanent": false
    },
    {
      "source": "/currency",
      "destination": "https://currency-frontend-3mdz.onrender.com/",
      "permanent": false
    },
    {
      "source": "/currency/(.*)",
      "destination": "https://currency-frontend-3mdz.onrender.com/$1",
      "permanent": false
    },
    {
      "source": "/games/snake",
      "destination": "https://zhzhhyzh.github.io/snake-game/",
      "permanent": false
    },
    {
      "source": "/games/snake/(.*)",
      "destination": "https://zhzhhyzh.github.io/snake-game/$1",
      "permanent": false
    },
    {
      "source": "/games/slot-verse",
      "destination": "https://zhzhhyzh.github.io/slot-verse/",
      "permanent": false
    },
    {
      "source": "/games/slot-verse/(.*)",
      "destination": "https://zhzhhyzh.github.io/slot-verse/$1",
      "permanent": false
    },
    {
      "source": "/games/count-stickman",
      "destination": "https://zhzhhyzh.github.io/count-stickman-game/",
      "permanent": false
    },
    {
      "source": "/games/count-stickman/(.*)",
      "destination": "https://zhzhhyzh.github.io/count-stickman-game/$1",
      "permanent": false
    },
    {
      "source": "/games/upgrade-car",
      "destination": "https://zhzhhyzh.github.io/upgrade-car-game/",
      "permanent": false
    },
    {
      "source": "/games/upgrade-car/(.*)",
      "destination": "https://zhzhhyzh.github.io/upgrade-car-game/$1",
      "permanent": false
    },
    {
      "source": "/games/dress-up",
      "destination": "https://zhzhhyzh.github.io/dress-up-game/",
      "permanent": false
    },
    {
      "source": "/games/dress-up/(.*)",
      "destination": "https://zhzhhyzh.github.io/dress-up-game/$1",
      "permanent": false
    },
    {
      "source": "/games/tetris",
      "destination": "https://zhzhhyzh.github.io/tetris-game/",
      "permanent": false
    },
    {
      "source": "/games/tetris/(.*)",
      "destination": "https://zhzhhyzh.github.io/tetris-game/$1",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server.js"
    },
    {
      "source": "/capture",
      "destination": "server.js"
    },
    {
      "source": "/pnc",
      "destination": "/pnc.html"
    },
    {
      "source": "/((?!api|assets|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
